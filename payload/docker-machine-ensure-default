#!/bin/sh
# Ensure the 'default' docker-machine VM is running, quietly.
# Driven by the dev.modernmavericks.container-tools-machine LaunchAgent (RunAtLoad + a timer),
# which ships DISABLED -- the user opts in with `launchctl load -w`.
#
# docker-machine's own `start` exits 1 when the machine is already running, which
# makes a naive KeepAlive respawn it every few seconds and flood system.log. This
# guard starts the machine ONLY when it exists and is not already Running, and always
# exits 0 so launchd has nothing to "recover." If no 'default' machine exists yet
# (user hasn't run `docker-machine create`), it does nothing.

DM=/usr/local/bin/docker-machine

# No 'default' machine (or docker-machine missing) -> nothing to do.
status=$("$DM" status default 2>/dev/null) || exit 0
[ "$status" = "Running" ] && exit 0

"$DM" start default >/dev/null 2>&1 || true
exit 0
