#!/bin/sh
# docker-machine-bootstrap — bring the Docker VM up and keep the docker CLI pointed at it,
# with no shell wiring. Idempotent; always exits 0 (safe for a LaunchAgent on a timer).
# Test seams (env; real defaults otherwise): MVD_ISO MVD_LOG MVD_STATE_DIR MVD_PROFILES
# MVD_FUSION_PRESENT MVD_NONINTERACTIVE
set -u

MACHINE=default
CONTEXT=mavericks
SELF=$(cd "$(dirname "$0")" && pwd)/$(basename "$0")
ISO=${MVD_ISO:-/usr/local/share/modernmavericks/container-tools/boot2docker.iso}
LOG=${MVD_LOG:-$HOME/Library/Logs/container-tools/bootstrap.log}
STATE_DIR=${MVD_STATE_DIR:-$HOME/Library/Application Support/container-tools}
PROFILES=${MVD_PROFILES:-$HOME/.bash_profile $HOME/.profile $HOME/.zshrc $HOME/.bashrc}

log() {
  mkdir -p "$(dirname "$LOG")" 2>/dev/null || true
  echo "$(date '+%Y-%m-%d %H:%M:%S') $*" >> "$LOG" 2>/dev/null || true
}

notify() { # key title message  (throttled to once/day per key)
  mkdir -p "$STATE_DIR" 2>/dev/null || true
  _stamp="$STATE_DIR/notified-$1"; _today=$(date '+%Y-%m-%d')
  [ -f "$_stamp" ] && [ "$(cat "$_stamp" 2>/dev/null)" = "$_today" ] && return 0
  echo "$_today" > "$_stamp" 2>/dev/null || true
  osascript -e "display notification \"$3\" with title \"$2\"" >/dev/null 2>&1 || true
}

fusion_present() {
  [ "${MVD_FUSION_PRESENT:-}" = 0 ] && return 1
  [ "${MVD_FUSION_PRESENT:-}" = 1 ] && return 0
  [ -d "/Applications/VMware Fusion.app" ] || command -v vmrun >/dev/null 2>&1
}

machine_status() { docker-machine status "$MACHINE" 2>/dev/null; }

create_machine() {
  log "creating machine 'default'"
  if [ "${MVD_NONINTERACTIVE:-}" = 1 ]; then
    docker-machine create -d vmwarefusion --vmwarefusion-boot2docker-url "$ISO" "$MACHINE" >>"$LOG" 2>&1
  else
    notify create "Container Tools for Mavericks" "Creating the Docker VM (one-time, ~1-2 min)..."
    _cmd="docker-machine create -d vmwarefusion --vmwarefusion-boot2docker-url '$ISO' $MACHINE && '$SELF'"
    osascript -e "tell application \"Terminal\" to do script \"$_cmd\"" >/dev/null 2>&1 || true
    osascript -e 'tell application "Terminal" to activate' >/dev/null 2>&1 || true
  fi
}

sync_context() {
  _env=$(docker-machine env "$MACHINE" 2>/dev/null) || return 0
  DOCKER_HOST=; DOCKER_CERT_PATH=
  eval "$_env" 2>/dev/null || return 0
  [ -n "${DOCKER_HOST:-}" ] || return 0
  _spec="host=$DOCKER_HOST,ca=$DOCKER_CERT_PATH/ca.pem,cert=$DOCKER_CERT_PATH/cert.pem,key=$DOCKER_CERT_PATH/key.pem"
  if docker context inspect "$CONTEXT" >/dev/null 2>&1; then
    _cur=$(docker context inspect "$CONTEXT" --format '{{.Endpoints.docker.Host}}' 2>/dev/null)
    if [ "$_cur" != "$DOCKER_HOST" ]; then
      docker context update "$CONTEXT" --docker "$_spec" >>"$LOG" 2>&1 || true
      log "context host -> $DOCKER_HOST"
    fi
  else
    docker context create "$CONTEXT" --docker "$_spec" >>"$LOG" 2>&1 || true
    log "context created -> $DOCKER_HOST"
  fi
  docker context use "$CONTEXT" >>"$LOG" 2>&1 || true
}

main() {
  if ! fusion_present; then
    log "VMware Fusion not found; skipping"
    notify fusion "Container Tools for Mavericks" "Install VMware Fusion to run the Docker VM."
    exit 0
  fi
  _status=$(machine_status)
  if [ -z "$_status" ]; then
    create_machine
    # Interactive create runs in a Terminal (chained to re-run SELF); nothing more to do now.
    [ "${MVD_NONINTERACTIVE:-}" = 1 ] || exit 0
    _status=$(machine_status)
  fi
  [ "$_status" = "Running" ] || docker-machine start "$MACHINE" >>"$LOG" 2>&1 || true
  [ "$(machine_status)" = "Running" ] && sync_context
  exit 0
}

main
