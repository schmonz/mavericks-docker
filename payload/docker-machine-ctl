#!/bin/sh
# docker-machine-ctl — the command surface the menu-bar app drives. Sources the shared
# helpers; every state-changing verb re-announces via write_state.
set -u
. "${MAVERICKS_DOCKER_COMMON:-/usr/local/libexec/modernmavericks/docker/docker-machine-common.sh}"

_run_and_announce() { # docker-machine subcommand
  docker-machine "$1" "$MACHINE" >>"$LOG" 2>&1
  _rc=$?
  write_state "$(status_word)"
  return $_rc
}

case "${1:-}" in
  status)  _w=$(status_word); write_state "$_w"; echo "$_w" ;;
  start)   _run_and_announce start ;;
  stop)    _run_and_announce stop ;;
  restart) _run_and_announce restart ;;
  login-status) launchctl list "$AGENT_LABEL" >/dev/null 2>&1 && echo on || echo off ;;
  login-on)  launchctl load -w "$AGENT_PLIST" >>"$LOG" 2>&1 ;;
  login-off) launchctl unload -w "$AGENT_PLIST" >>"$LOG" 2>&1 ;;
  setup)   exec docker-machine-bootstrap ;;
  vmx-pid) pgrep -f "machines/$MACHINE/.*\.vmx" 2>/dev/null | head -1 || true ;;
  *) echo "usage: docker-machine-ctl {status|start|stop|restart|login-status|login-on|login-off|setup|vmx-pid}" >&2; exit 2 ;;
esac
